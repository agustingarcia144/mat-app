# Only hoist dev tools to root, not runtime dependencies like React
# This prevents React from being hoisted, allowing each app to use its own version
# Mobile needs React 19.1.0, web needs React 19.2.3
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
public-hoist-pattern[]=typescript
public-hoist-pattern[]=turbo

# Use isolated node linker (default for pnpm 8+) to prevent React hoisting
# Expo SDK 54+ supports isolated dependencies
node-linker=isolated
