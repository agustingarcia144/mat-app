{
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "convex:dev": "pnpm --filter convex dev",
    "convex:deploy": "pnpm --filter convex deploy",
    "convex:codegen": "pnpm --filter convex codegen"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "tsup": "^8.5.1",
    "turbo": "^2.7.5",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.6",
      "@types/react-dom": "19.2.3",
      "react": "19.2.0",
      "react-dom": "19.2.0"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "browser-tabs-lock",
      "bufferutil",
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "name": "mat-app",
  "packageManager": "pnpm@10.28.2"
}
