{
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "convex:dev": "pnpm --filter convex dev",
    "convex:deploy": "pnpm --filter convex deploy",
    "convex:codegen": "pnpm --filter convex codegen",
    "android": "pnpm --filter mobile run android",
    "ios": "pnpm --filter mobile run ios",
    "testflight": "pnpm --filter mobile run testflight"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "5.9.3",
    "xmlbuilder": "15.1.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.17",
      "@types/react-dom": "19.1.0"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "browser-tabs-lock",
      "bufferutil",
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ],
    "patchedDependencies": {
      "@clerk/expo@3.1.4": "patches/@clerk__expo@3.1.4.patch",
      "expo-dev-launcher@55.0.27": "patches/expo-dev-launcher@55.0.27.patch"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "name": "mat-app",
  "packageManager": "pnpm@10.33.0"
}
